@35000 = ~Rzuć kośćmi, by zyskać fortunę. Podwój swoją stawkę przy wygrywającym rzucie.~
@35001 = ~Stawiam 100 sztuk złota.~
@35002 = ~Stawiam 250 sztuk złota.~
@35003 = ~Nie, dziękuję.~
@35004 = ~Pani uśmiecha się do ciebie! Biorę twoje 100 sztuk złota i daję ci 200!~
@35005 = ~Pani uśmiecha się do ciebie! Biorę twoje 250 sztuk złota i daję ci 500!~
@35006 = ~Pani odwraca wzrok i przegrywasz! Przykro mi. Następny!~
@35007 = ~Odsuń się. Blokujesz płacących klientów.~