@36000 = ~Na Garla, to Europea! Szybko, oddaj mi ją, bym mógł opatrzyć jej rany.~
@36001 = ~Biedne dziecko, gdzieś ty się podziewała przez te wszystkie lata?~
@36002 = ~Żyła jako niewolnica u kogoś w Beregoście, dopóki nie udało jej się uciec. W końcu schwytali ją łowcy nagród i wtedy interweniowałem.~ ~Żyła jako niewolnica u kogoś w Beregoście, dopóki nie udało jej się uciec. W końcu schwytali ją łowcy nagród i wtedy interweniowałam.~
@36003 = ~To by wyjaśniało to urządzenie na jej szyi. Prawdopodobnie oprawca używał go, by przyćmić jej umysł. Czekaj, spróbuję je zdjąć.~
@36004 = ~Właściwie to przydałaby mi się ta obroża. Jeśli ją odniosę, uznają ją za martwą i odwołają polowanie.~
@36005 = ~Oddałeś nam wielką przysługę i dziękuję ci za to z całego serca.~ ~Oddałaś nam wielką przysługę i dziękuję ci za to z całego serca.~
@36006 = ~Cała przyjemność po mojej stronie.~
@36007 = ~Liczyłem na jakąś nagrodę.~ ~Liczyłam na jakąś nagrodę.~
@36008 = ~Żegnaj, przyjacielu.~ ~Żegnaj, przyjaciółko.~
@36009 = ~Oczywiście, że tak. Pamiętam czasy, gdy pomaganie innym dawało satysfakcję i nie wymagało nagród.~