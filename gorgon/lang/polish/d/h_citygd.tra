// Strażnicy buntownicy - h_citygd.tra

@25000 = ~Ruszajcie do świątyni! My zajmiemy się resztą!~
@25001 = ~Straż Miejska potrzebuje nowego początku – i to my mamy ją ku temu poprowadzić!~
@25002 = ~Stara gwardia nas zawiodła. Pora na nową erę w Straży Miejskiej!~
@25003 = ~Czas Białokniei dobiegł końca. Odzyskujemy kontrolę nad własnym losem!~
@25004 = ~Upór Białokniei wpędzi nas wszystkich do grobu. Musimy znaleźć sposób na zakończenie tej wojny.~
@25005 = ~Duma Białokniei przysłania jej realny obraz sytuacji. Musimy podjąć negocjacje z Okiem Gorgony.~
@25006 = ~Nie możemy dalej poświęcać życia za ideały Białokniei. Czas zawrzeć rozejm.~
@25007 = ~Komendantka uciekła na wschód, by szukać schronienia w świątyni. Tutaj stawimy nasz ostatni opór!~