// Diomedes - h_deaded.tra

@28500 = ~Tak, przyjacielu, to nie jest miejsce dla ludzi o słabych nerwach. Lepiej znajdź sobie inne zajęcie, co? Ruchy.~
@28501 = ~Musisz być tą świeżą krwią, co? Witaj na arenie. Jestem Diomedes, a to moja szacowna towarzyszka, Cień. Nie daj się zwieść jej uroczej aparycji, ma nosa do dobrej walki.~ 
@28502 = ~Ty tu rządzisz, Diomedesie? Czym dokładnie jest ta arena?~
@28503 = ~Kto jest obecnym mistrzem areny?~
@28504 = ~Jak twoja praca tutaj łączy się z operacjami Oka Gorgony?~
@28505 = ~Jaka historia stoi za twoją kotką? Wygląda na taką, która widziała już sporo akcji.~
@28506 = ~Chcę się sprawdzić na arenie. Jak mogę dołączyć do walk?~
@28507 = ~Muszę już iść.~
@28508 = ~Mistrz areny... to tytuł, który niełatwo zdobyć i jeszcze trudniej utrzymać. Obecnie dzierży go Roran, bezlitosny wojownik, który bez litości miażdży przeciwników.~
@28509 = ~Przed nim była Isla Mroczny Płaszcz, legenda sama w sobie. Była tą, z którą należało się liczyć, łącząc siłę i technikę w sposób, jaki rzadko jest widywany.~
@28510 = ~Teraz jest na emeryturze, ale pozostawiła po sobie dziedzictwo, któremu trudno dorównać. Jeśli zamierzasz rzucić wyzwanie Roranowi, musisz przygotować się na brutalną walkę.~
@28511 = ~Ach, Cień... towarzyszy mi już tak długo, że aż nie chce się liczyć lat. Trafiłem na nią w zaułkach Beregostu – chuda, na skraju życia. Wykarmiłem ją i doprowadziłem do siebie.~
@28512 = ~Od tamtej pory jest moją nieodłączną towarzyszką, nigdy nie odstępuje mnie na krok, zwłaszcza w wirze walki.~
@28513 = ~Ma niesamowity zmysł do wykrywania niebezpieczeństwa. Ratowała mi skórę częściej, niż zdołam zliczyć. W pewnym sensie jest prawdziwym sercem tej areny – zawsze czujna, zawsze uważna.~
@28514 = ~Sprawa jest prosta: arena to interes działający dwutorowo. Złoto płynie regularnie – przede wszystkim z zakładów i spragnionego emocji tłumu.~
@28515 = ~Poza tym służy jako miejsce szkoleniowe dla ludzi z Oka Gorgony – tu kandydaci mogą zapracować na swoją pozycję.~
@28516 = ~Uznani członkowie gildii schodzą tu, by szlifować umiejętności i nauczyć się czegoś od moich wojowników. Trening bojowy, dyscyplina i posmak krwi. Wszystko to wykuwa się właśnie tutaj.~
@28517 = ~Arena to pole bitwy, arena pojedynków – miejsce, gdzie dwóch wojowników staje naprzeciw siebie w tańcu żelaza i umiejętności.~
@28518 = ~Ale pamiętaj, nie chodzi tu o walki na śmierć i życie. Chodzi o doskonalenie zdolności, przesuwanie granic i pokazywanie światu, z czego ulepiony jest prawdziwy wojownik.~
@28519 = ~Kujemy siłę, ostrzymy umysły i hartujemy ducha. To coś więcej niż scena dla wojowników. To tutaj odnajdujemy swoje prawdziwe ja i dowiadujemy się, do czego naprawdę jesteśmy zdolni.~
@28520 = ~Niecierpliwisz się, co? Podoba mi się to. Zanim jednak zatopisz się w walkach, warto rozeznać się w terenie. Porozmawiaj z wojownikami, wyczuj rytm i poznaj sztuczki branży. To ci dobrze zrobi.~
@28521 = ~Gdy uznasz, że już to ogarniasz, wróć do mnie, a zorganizujemy ci walkę. Pamiętaj, cierpliwość i wiedza są na tej arenie równie ważne co żelazo.~
@28522 = ~Masz ten błysk w oku – jakbyś czegoś szukał. O co chodzi? Chcesz spróbować sił na arenie, czy tylko zebrać trochę informacji?~ ~Masz ten błysk w oku – jakbyś czegoś szukała. O co chodzi? Chcesz spróbować sił na arenie, czy tylko zebrać trochę informacji?~
@28523 = ~Jestem gotowy wejść na arenę, Diomedesie. Zróbmy to.~ ~Jestem gotowa wejść na arenę, Diomedesie. Zróbmy to.~
@28524 = ~Są tu jakieś zasady, o których powinienem wiedzieć?~ ~Są tu jakieś zasady, o których powinnam wiedzieć?~
@28525 = ~Czy za udział w walkach przewidziane są nagrody?~
@28526 = ~Chcę sprawdzić, co u Cień. Jak się dziś czuje? Mogę ją trochę pogłaskać?~
@28527 = ~Tak, zasady są proste, ale kluczowe dla samych fundamentów tego, co tu robimy. Żadnej magii i żadnego zabijania.~
@28528 = ~Widzisz, tu nie chodzi o czary ani śmierć. Jesteśmy tu dla czystych umiejętności, dla sztuki walki. Magia zwykle przechyla szalę, a my chcemy uczciwego starcia.~
@28529 = ~Co do śmiertelnych ciosów – nie chodzi o to, że stronimy od intensywności. Wręcz przeciwnie. Ale nie jesteśmy katami. Jesteśmy tu dla zaciekłych bitew, nie dla bezsensownego rozlewu krwi.~
@28530 = ~Zapamiętaj więc dobrze te zasady. Są kręgosłupem tego, co robimy na arenie. Dzięki nim każde zwycięstwo jest wypracowane, każda porażka jest lekcją, a każdy pojedynek prawdziwym spektaklem.~
@28531 = ~Oczywiście. Po pierwsze i najważniejsze, to bezcenne doświadczenie. Nic nie zastąpi lekcji odebranych w wirze bitwy.~
@28532 = ~A dla tych, którzy się wykażą, przewidziano udział w zyskach. Widzisz, nie jesteśmy tu tylko dla sportu – jesteśmy tu, by dawać rozrywkę, a tłum chętnie okazuje wdzięczność.~
@28533 = ~Masz dobre oko do zwierząt, przyjacielu. Koty wiedzą, jak znajdować właściwych ludzi. Tylko bądź z nią delikatny, dobrze?~ ~Masz dobre oko do zwierząt, przyjaciółko. Koty wiedzą, jak znajdować właściwych ludzi. Tylko bądź z nią delikatna, dobrze?~
@28534 = ~Gotowy, by rzucić się w wir akcji? To mi się podoba! Nie traćmy czasu.~ ~Gotowa, by rzucić się w wir akcji? To mi się podoba! Nie traćmy czasu.~
@28535 = ~Pamiętaj, jak tu działamy. Żadnej magii, trzymamy się starej szkoły. I żadnych śmiertelnych ciosów – jesteśmy tu dla sportu, nie dla rzezi.~
@28536 = ~Przygotuj sprzęt i wchodzimy na arenę.~
@28537 = ~Ruszajmy.~
@28538 = ~Po namyśle, potrzebuję jeszcze trochę czasu na przygotowanie.~
@28539 = ~Na pierwszy ogień zestawimy cię z Khalimem. Ma smykałkę do odkrywania słabości wojowników. Chcę w końcu zobaczyć, z jakiej gliny jesteś ulepiony.~ ~Na pierwszy ogień zestawimy cię z Khalimem. Ma smykałkę do odkrywania słabości wojowników. Chcę w końcu zobaczyć, z jakiej gliny jesteś ulepiona.~
@28540 = ~Następny będzie Grom. To siła, z którą trzeba się liczyć, zupełnie inna bestia. Bądź gotowy na trudną walkę.~ ~Następny będzie Grom. To siła, z którą trzeba się liczyć, zupełnie inna bestia. Bądź gotowa na trudną walkę.~
@28541 = ~Zaczynasz przyciągać tłumy. Ludzie słyszą o świeżej krwi, która pokonuje wszystkich moich wojowników. Nie zawiedźmy ich, co?~
@28542 = ~Dobra. Szykuj się, stajesz przeciwko Lyrii Zimowe Serce. Jest przebiegła, więc miej się na baczności.~
@28543 = ~Twoim następnym wyzwaniem będzie Serra Prędki Wiatr, zamaskowana łuczniczka. Zachowaj trzeźwy umysł, bo jest równie ostra jak jej strzały. Powodzenia, przyjacielu.~ ~Twoim następnym wyzwaniem będzie Serra Prędki Wiatr, zamaskowana łuczniczka. Zachowaj trzeźwy umysł, bo jest równie ostra jak jej strzały. Powodzenia, przyjaciółko.~
@28544 = ~Przeszedłeś długą drogę, a teraz stajesz u szczytu areny. Roran „Żelazna Pięść” Głazołamacz, panujący mistrz.~ ~Przeszłaś długą drogę, a teraz stajesz u szczytu areny. Roran „Żelazna Pięść” Głazołamacz, panujący mistrz.~
@28545 = ~To siła natury, mnich o pięściach, które mogą kruszyć kamień. Miej się na baczności i walcz mądrze. To nie będzie łatwe starcie.~
@28546 = ~Od momentu, gdy postawiłeś stopę na tej arenie, widziałem w tobie coś wyjątkowego. Udowodniłeś mi to w najbardziej spektakularny sposób.~ ~Od momentu, gdy postawiłaś stopę na tej arenie, widziałem w tobie coś wyjątkowego. Udowodniłaś mi to w najbardziej spektakularny sposób.~
@28547 = ~Pokonanie Rorana, panującego mistrza, to nie lada wyczyn. Przerosłeś wszelkie oczekiwania.~ ~Pokonanie Rorana, panującego mistrza, to nie lada wyczyn. Przerosłaś wszelkie oczekiwania.~
@28548 = ~Na arenie nie został nikt, kto mógłby rzucić ci wyzwanie. No może poza Islą, ale ona dawno przeszła na emeryturę.~
@28549 = ~Stała się jedną z najbardziej niesławnych zabójczyń i najemniczek, jakie widziało Wybrzeże Mieczy. Nikt nie wie, gdzie teraz jest, nawet ja.~
@28550 = ~Zostawiła to wszystko, zniknęła w cieniu. Znalezienie jej nie będzie łatwe, ale jeśli uparłeś się, by dowieść swej wartości, to właśnie ją będziesz musiał przekonać.~ ~Zostawiła to wszystko, zniknęła w cieniu. Znalezienie jej nie będzie łatwe, ale jeśli uparłaś się, by dowieść swej wartości, to właśnie ją będziesz musiała przekonać.~
@28551 = ~Na bogów, dokonałeś niemożliwego! Udało ci się przekonać Islę do powrotu na arenę! Nigdy nie sądziłem, że dożyję tego dnia.~ ~Na bogów, dokonałaś niemożliwego! Udało ci się przekonać Islę do powrotu na arenę! Nigdy nie sądziłem, że dożyję tego dnia.~
@28552 = ~Od lat nie pozwalałem na walki na śmierć i życie, ale dla dwóch czempionów takiego kalibru... to zbyt wielka okazja, by ją przepuścić.~ ~Od lat nie pozwalałem na walki na śmierć i życie, ale dla dwóch czempionek takiego kalibru... to zbyt wielka okazja, by ją przepuścić.~
@28553 = ~To będzie bitwa wszech czasów, starcie, które poniesie się echem w kronikach historii walk na arenie.~
@28554 = ~Mistrzu, kiedy będziesz gotowy, powiedz tylko słowo i ruszymy na arenę. Arena czeka, tak jak czeka i Isla. Tak właśnie na naszych oczach tworzy się historia!~ ~Mistrzyni, kiedy będziesz gotowa, powiedz tylko słowo i ruszymy na arenę. Arena czeka, tak jak czeka i Isla. Tak właśnie na naszych oczach tworzy się historia!~
@28555 = ~Jestem gotowy, Diomedesie.~ ~Jestem gotowa, Diomedesie.~
@28556 = ~Potrzebuję jeszcze trochę czasu na przygotowanie.~
@28557 = ~Pamiętaj, mistrzu, to walka na śmierć i życie. Pokaż światu swoje prawdziwe możliwości.~ ~Pamiętaj, mistrzyni, to walka na śmierć i życie. Pokaż światu swoje prawdziwe możliwości.~
@28558 = ~Niech mnie kule biją. Wszedłeś na tą arenę jako zagadka, jako nikt. Spójrz na siebie teraz. Wspiąłeś się w rankingu, pokonałeś najtwardszych wojowników, nawet samą Islę.~ ~Niech mnie kule biją. Weszłaś na tą arenę jako zagadka, jako nikt. Spójrz na siebie teraz. Wspięłaś się w rankingu, pokonałaś najtwardszych wojowników, nawet samą Islę.~
@28559 = ~To coś więcej niż mistrzostwo, przyjacielu. Stałeś się legendą – a nie mówię tego ot tak. Oto twoja zasłużona nagroda. Każdą monetę uczciwie wywalczyłeś.~ ~To coś więcej niż mistrzostwo, przyjaciółko. Stałaś się legendą – a nie mówię tego ot tak. Oto twoja zasłużona nagroda. Każdą monetę uczciwie wywalczyłaś.~
@28560 = ~Noś swój tytuł z dumą, Mistrzu. Arena nigdy nie zapomni twojego imienia.~ ~Noś swój tytuł z dumą, Mistrzyni. Arena nigdy nie zapomni twojego imienia.~
@28561 = ~Pamiętaj, mistrzu, wpisałeś swoje imię w historię tej areny. Legenda o twoim triumfie będzie odbijać się echem przez wieki.~ ~Pamiętaj, mistrzyni, wpisałaś swoje imię w historię tej areny. Legenda o twoim triumfie będzie odbijać się echem przez wieki.~
@28562 = ~Zabierz łupy i noś swój tytuł z dumą. Do zobaczenia następnym razem na arenie!~