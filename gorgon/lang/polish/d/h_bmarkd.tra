// Handlarz czarnorynkowy - h_bmarkd.tra

@18500 = ~Naciesz oczy wyborem moich najbardziej zabójczych specjałów. Mam strzały, strzałki, bełty i pociski, po których twoi wrogowie wyzioną ducha, nim zdążą poprosić o litość.~
@18501 = ~Pokaż mi, co tam masz.~ 
@18502 = ~Nie teraz.~
@18503 = ~Proszę bardzo, przyjacielu.~ ~Proszę bardzo, przyjaciółko.~