@57500 = ~Masz ochotę na małą zabawę w „znalezione, nie kradzione”?~
@57501 = ~Wytrychów nigdy za wiele, a świadków nigdy za mało.~
@57502 = ~Cień to mój dom, a cisza to jedyna kumpela.~
@57503 = ~Chodź cicho, mów szeptem, a zajdziesz daleko w tej branży.~
@57504 = ~Cierpliwość to najlepszy przyjaciel złodzieja, a zaraz po niej idzie solidny wytrych.~
@57505 = ~Poznaj swój cel, ale nie daj się poznać jemu.~
@57506 = ~Klucz do dobrego skoku? Wyczucie czasu i stalowe nerwy.~
@57507 = ~Dobry fachowiec wie, kiedy czekać, a kiedy uderzyć.~
@57508 = ~Oglądaj się za siebie.~