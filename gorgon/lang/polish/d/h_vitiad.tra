@66000 = ~No proszę, wygląda na to, że mamy wyjątkowo ciekawskiego gościa. Co cię sprowadza na nasze małe spotkanie?~ ~No proszę, wygląda na to, że mamy wyjątkowo ciekawską towarzyszkę. Co cię sprowadza na nasze małe spotkanie?~
@66001 = ~Czekaj chwilę, ja cię znam! To ty zwinąłeś moje złoto przy namiotach hazardzistów!~
@66002 = ~Ach, więc to ty jesteś tą ofiarą, na którą wtedy trafiłem! Cóż, nie ma o czym mówić. Marne sto sztuk złota to drobnostka w ogólnym rozrachunku. To była tylko niewinna zabawa, zapewniam cię.~
@66003 = ~Masz, bierz z powrotem. Nie ma sensu trzymać takich nędznych groszy. Potraktuj to jako sprawdzian sprytu, przyjacielu.~ ~Masz, bierz z powrotem. Nie ma sensu trzymać takich nędznych groszy. Potraktuj to jako sprawdzian sprytu, przyjaciółko.~
@66004 = ~Cień i dryg – oto metoda Vitiarego. Patrz i ucz się, przyjacielu.~ ~Cień i dryg – oto metoda Vitiarego. Patrz i ucz się, przyjaciółko.~
@66005 = ~Oto i on – niesławny Vitiare, mistrz cieni i zdobywca fortun!~
@66006 = ~W złodziejskim fachu nikt nie dorówna Vitiaremu pod względem finezji i sprytu!~
@66007 = ~Dla jednych to kradzież, dla mnie to po prostu zdobywanie tego, co mi się słusznie należy – siłą umysłu lub podstępem.~