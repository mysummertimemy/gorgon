@53500 = ~Cóż, mówią, że taniec to tylko pionowy wstęp do poziomych uciech.~
@53501 = ~No proszę, ileż w tobie odwagi. Mam nadzieję, że dotrzymasz mi... kroku.~
@53502 = ~Ach, noc jest młoda, tak samo jak my. Wyciśnijmy z niej wszystko, co się da!~
@53503 = ~W twych oczach widzę ten szczególny żar. Ciekawe, co jeszcze skrywasz tu, głęboko pod powierzchnią?~
@53504 = ~Jesteś prawdziwą zagadką, kochanie. Ciekawe, jakie sekrety tylko czekają, aż je odkryję?~
@53505 = ~Powiadają, że prawdziwa bliskość rodzi się w ciszy między słowami. Chcesz sprawdzić, czy to prawda?~
@53506 = ~Nie sądzisz, że taka noc wymaga brawurowych czynów i odważnych serc?~
@53507 = ~Ależ iskrzy między nami, nie uważasz?~