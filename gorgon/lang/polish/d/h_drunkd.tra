// Pijak - h_drunkd.tra

@31000 = ~Nie jesztem piiijany, po prosztu ćwiczę taniec interpretacyjny!~
@31001 = ~Mam szószty zmyszł... do znajdowania najbliżzszej beczki miodu.~
@31002 = ~Widzisz, sekret dobrego miodu tkwi w... *czka*... lejesz, póki widzisz kufel.~
@31003 = ~Posztanowiłem zosztać rycerzem! Już opanowałem sztarodawną sztukę... chwiania się.~
@31004 = ~Wiesz, co mówią: kufel piwa dziennie trzyma... ugh... coś tam z daleka! Więcej piwa, powiadam!~
@31005 = ~Mam szekreet... *beka*... smok to po prosztu taka naprawdę duża jaszczurka, nie?~
@31006 = ~Mam genialny pomysł! Będziemy... będziemy... och, uciekło mi.~
@31007 = ~Wiesz, że noc jeszt wspaniała, kiedy podłoga zaczyna prawić ci komplementy.~