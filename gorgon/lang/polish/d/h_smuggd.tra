@59000 = ~Podnoszę rzeczy i je kładę. Tyle że nigdy w tym samym miejscu.~
@59001 = ~Robię interesy w mroku, tam, gdzie prawo boi się zaglądać.~
@59002 = ~Przyprawa, kontrabanda, czegokolwiek dusza zapragnie. Dostarczę ci to pod same drzwi.~
@59003 = ~Nie znajdziesz żadnego śladu po mnie ani po ładunku.~
@59004 = ~Niech inni bawią się złotem. My handlujemy czymś znacznie bardziej... intrygującym.~
@59005 = ~Pierwsza zasada przemytu... nigdy nie daj się złapać!~
@59006 = ~Przez góry i lasy, dotrę wszędzie, by dostarczyć towar.~
@59007 = ~Najlepsze szlaki zna niewielu, a dzieli się nimi jeszcze mniej osób.~