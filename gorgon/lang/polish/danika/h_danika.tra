@2000 = ~Ci, którzy służą Panu Cieni, nie dzielą się sekretami z nieznajomymi. Radzę więc uważać, bo cienie patrzą i pamiętają.~
@2001 = ~Dyskrecja i obowiązek nie pozwalają mi na dalszą rozmowę. Dopóki nie staniesz w naszych szeregach, nie mamy o czym gadać.~
@2002 = ~Bracia z Oka Gorgony, niech cienie sprzyjają waszym poczynaniom... a teraz sprzyja im też Kościół Maski. Jestem Danika, nowo mianowana demarchini naszego Pana Cieni.~
@2003 = ~Jako wasza sojuszniczka i przewodniczka, mam zamiar nasycić nasze operacje boskim pierwiastkiem. Dopilnuję, by nie tylko kończyły się sukcesem, ale i były świadectwem naszego oddania.~
@2004 = ~Nasz Pan ceni subtelność i przebiegłość – cechy, które i mi są bliskie. Liczę na owocną współpracę i na to, że uda mi się przekazać wam nieco mądrości naszej wiary.~
@2005 = ~Razem, pod czujnym okiem Maski, zdefiniujemy sztukę złodziejstwa na nowo. Sprawimy, że nazwa Oka Gorgony będzie budzić lęk i szacunek w równym stopniu.~
@2006 = ~Saradin wspomniał o możliwej współpracy między nami. Co ty na to?~
@2007 = ~Chciałbym dowiedzieć się czegoś więcej o Kościele Maski.~ ~Chciałabym dowiedzieć się czegoś więcej o Kościele Maski.~
@2008 = ~Mówiąc konkretnie: co możesz mi zaoferować? Jak mogę wykorzystać twoje umiejętności?~
@2009 = ~Chciałbym dowiedzieć się czegoś o tobie, Daniko. Masz ochotę coś o sobie opowiedzieć?~ ~Chciałabym dowiedzieć się czegoś o tobie, Daniko. Masz ochotę coś o sobie opowiedzieć?~
@2010 = ~Doceniam twój czas, ale muszę już iść. Mam sprawy, którymi muszę się zająć.~
@2011 = ~Jakie cienie dręczą twoje myśli i jak przewodnictwo sługi Maski może ci pomóc na tej zawiłej ścieżce?~
@2012 = ~Chciałbym, żebyś do mnie dołączyła, jeśli wciąż masz na to ochotę. Twoje doświadczenie bardzo by nam pomogło.~ ~Chciałabym, żebyś do mnie dołączyła, jeśli wciąż masz na to ochotę. Twoje doświadczenie bardzo by nam pomogło.~
@2013 = ~Niech cienie prowadzą twoje kroki, wierny druhu. Kiedy będziesz potrzebować rady lub zapragniesz ujrzeć to, co niewidoczne, wiedz, że będę tutaj, w objęciach nocy, gotowa dzielić się mądrością Maski.~ ~Niech cienie prowadzą twoje kroki, wierna towarzyszko. Kiedy będziesz potrzebować rady lub zapragniesz ujrzeć to, co niewidoczne, wiedz, że będę tutaj, w objęciach nocy, gotowa dzielić się mądrością Maski.~
@2014 = ~Ach, poszukiwacz prawd ukrytych w świecie cieni. Rzadko spotyka się kogoś tak chętnego, by zajrzeć za kurtynę Kościoła Maski.~ ~Ach, poszukiwaczka prawd ukrytych w świecie cieni. Rzadko spotyka się kogoś tak chętnego, by zajrzeć za kurtynę Kościoła Maski.~
@2015 = ~Powiedz mi, która nitka tej zawiłej sieci najbardziej cię ciekawi? Jaką wiedzę chcesz odsłonić?~
@2016 = ~Możesz opowiedzieć mi w skrócie historię Kościoła? Jak zmieniał się przez lata?~
@2017 = ~Jakie są główne wierzenia i dogmaty wyznawców Maski?~
@2018 = ~Jak zorganizowany jest wasz Kościół? Jakie role i hierarchie w nim panują?~
@2019 = ~Czym dokładnie zajmuje się Kościół? Jak planujecie i przeprowadzacie swoje akcje?~
@2020 = ~Czy macie jakieś rytuały lub ceremonie, które są unikalne dla waszej wiary?~
@2021 = ~Jakiego rodzaju magia jest kojarzona z waszym Kościołem? Czy są jakieś zaklęcia, których mógłbym się nauczyć?~ ~Jakiego rodzaju magia jest kojarzona z waszym Kościołem? Czy są jakieś zaklęcia, których mogłabym się nauczyć?~
@2022 = ~Jak Kościół Maski układa sobie relacje z innymi bóstwami i ich wyznawcami?~
@2023 = ~Chciałbym zapytać o coś innego.~ ~Chciałabym zapytać o coś innego.~
@2024 = ~Kościół Maski, spowity tajemnicą, ma długą i mroczną historię, głęboko wplecioną w tkankę Faerûnu. Od zarania dziejów był sanktuarium dla tych, którzy najlepiej czują się w ciemności.~
@2025 = ~Początkowo Kościół jawniej mieszał się w polityczne intrygi i spiski na wielką skalę. Jednak po Czasie Niepokojów i dojściu do potęgi Cyrica, nasz cel się zmienił.~
@2026 = ~Zeszliśmy głębiej w cień, dopracowując nasze metody tak, by były bardziej osobiste, nieuchwytne i skupione na działaniu w mniejszych grupach.~
@2027 = ~Ta ewolucja była niezbędna, by przetrwać na zmieniającej się scenie boskich i politycznych potęg. Nasza historia to opowieść o adaptacji i przetrwaniu – świadectwo niezmiennej natury cieni.~
@2028 = ~Kościół Maski opiera się na przekonaniu, że świat należy do przebiegłych, skrytych i zaradnych.~
@2029 = ~Wyznajemy zasadę, że własność to pojęcie płynne – liczy się to, co masz w ręku, a nie prawo czy tradycja. Sztuka oszustwa, subtelność i umiejętność manipulacji to cnoty, które pielęgnujemy.~
@2030 = ~Bogactwo należy do tych, którzy potrafią je zręcznie zdobyć.~
@2031 = ~Nasze zasady zachęcają nas, by kończyć każdy dzień bogatszym, niż się go zaczęło. Nie siłą, lecz sprytem i skradaniem.~
@2032 = ~Uczciwość? To nie cnota, a narzędzie do tworzenia fasady – maski, jeśli wolisz – która pomaga nam osiągać cele.~
@2033 = ~W gruncie rzeczy jesteśmy zgromadzeniem ludzi, którzy kochają skrytość i dyskrecję.~
@2034 = ~W naszych szeregach znajdziesz głównie złodziei, kapłanów i wyspecjalizowanych duchownych, do których sama się zaliczam.~
@2035 = ~Tytuły takie jak „Ukryci” noszą najbardziej szanowani członkowie, jak mój mistrz, Saradin. To najwyżsi kapłani naszego zakonu.~
@2036 = ~To oni są przewodnimi cieniami, niewidocznymi dłońmi, które kształtują naszą drogę. Ale nasza struktura nie ogranicza się tylko do świątyń i mrocznych sanktuariów.~
@2037 = ~W tętniących życiem miastach spotkasz „Kocie Łapy” – duchownych, którzy wtapiają się w tłum, zbierając informacje i pomagając braciom po fachu.~
@2038 = ~„Nocni Biegacze” wybierają inną drogę – przemierzają dzicz i badają lochy. Są naszymi oczami i uszami tam, gdzie nie sięgają miejskie mury. Błogosławieństwo Maski nie kończy się przecież na bramach miasta.~
@2039 = ~Każdy z nas, bez względu na tytuł, doskonali umiejętności przynoszące chwałę Masce. Czy to sztuka kamuflażu, fałszerstwa, czy czytania z ruchu warg – szkolą nas, byśmy byli wcieleniem naszego bóstwa.~
@2040 = ~Jak widzisz, czy to w korytarzach świątyni, czy w dzikich ostępach, Kościół Maski kwitnie dzięki sprytowi i zrozumieniu mroku, który nazywamy domem.~
@2041 = ~Nasze zajęcia są tak różnorodne, jak cienie, w których mieszkamy. Przede wszystkim szpiegostwo, kradzieże i subtelna manipulacja.~
@2042 = ~Planujemy operacje skrupulatnie – od misternych włamań po zbieranie informacji i infiltrację. Wolimy działać niebezpośrednio, pozostać niezauważeni i nieuchwytni.~
@2043 = ~Działania Kościoła mają być jak szept ducha w ciemności – bez śladu, ale z potężnym skutkiem. Każdy czyn, każda kradzież, każdy zdobyty sekret to hołd dla Maski.~
@2044 = ~Nasze praktyki są równie zagadkowe, co nasz bóg. Rytuał Niewidzialnej Obecności to święty obrzęd, w którym uznajemy wszechobecność Maski w ciemnościach.~
@2045 = ~Podczas tej uroczystej ceremonii składamy Masce w ofierze skradzione bogactwa, przetapiając je przed ołtarzami.~
@2046 = ~Inną ważną tradycją jest Rytuał Kroczenia w Cieniu, który pozwala wyznawcy zestroić się z samą istotą mroku.~
@2047 = ~Te ceremonie, jak większość naszych praktyk, są tajne i odbywają się pod strażą przywołanych cieni, by nikt niepowołany ich nie ujrzał.~
@2048 = ~Używamy magii, która ułatwia skradanie, mami innych i pozwala manipulować mrokiem. Zaklęcia takie jak Mroczna Ścieżka, Słuchający Cień czy Uderzające Cienie to nasza codzienność.~
@2049 = ~Dzięki nim wtapiamy się w ciemność, podsłuchujemy bez ryzyka i uderzamy tam, gdzie nikt się nas nie spodziewa.~
@2050 = ~Nauka tych sztuk wymaga pełnego oddania Masce i zrozumienia natury mroku.~
@2051 = ~Nasze relacje z innymi bóstwami i ich wyznawcami są, podobnie jak nasza praca, złożone i wielowymiarowe.~
@2052 = ~To gęsta sieć sojuszy i waśni. Najbardziej znacząca jest nasza głęboka nienawiść do Cyrica.~
@2053 = ~Ta uraza bierze się z mrocznego rozdziału naszej historii. Podczas Czasu Niepokojów, Maska, pod postacią miecza Zabójcy Bogów, został użyty przez Cyrica do zgładzenia Bhaala, Pana Mordu.~
@2054 = ~Niestety, misterne plany Maski zakończyły się katastrofalnym błędem.~
@2055 = ~Niechcący pomógł Cyricowi przejąć domenę iluzji, a co gorsza, stracił znaczną część własnej potęgi, w tym domenę intrygi.~
@2056 = ~Ta wpadka nie tylko osłabiła Maskę, ale i rozpaliła wieczną zemstę przeciwko Cyricowi. Poza tym, zamiłowanie naszego boga do intryg często stawia nas w opozycji do innych.~
@2057 = ~Maska szukał sojuszy, choćby z Bane'em, ale takie propozycje zawsze budzą nieufność ze względu na reputację naszego boga.~
@2058 = ~Sprzeciwiają nam się bóstwa pokroju Waukeen i Helma, a inni, jak Deneir, Oghma, Torm, Tyr czy Selûne, zawsze starają się krzyżować plany Maski.~
@2059 = ~Jednocześnie nasze relacje z Shar są specyficzne, bo nasze domeny – mrok i sekrety – mocno się pokrywają.~
@2060 = ~Choć Maska to zazwyczaj samotnik, z Shar łączy go nić wzajemnego zrozumienia natury cieni, choć nie jest to ani otwarty sojusz, ani czysta wrogość.~
@2061 = ~Ta dynamika pokazuje, jak po kruchym lodzie musimy stąpać w świecie boskich wpływów.~
@2062 = ~Nasz Kościół musi być tak przebiegły i elastyczny jak cienie, które czcimy. Zawsze czujny w świecie, gdzie sojusze zmieniają się szybciej niż zapada zmierzch.~
@2063 = ~Moje wsparcie dla Oka Gorgony jest jak cień-przewodnik – oferuję rady strategiczne i spostrzeżenia, które wyniosą nasze operacje na nowy poziom.~
@2064 = ~Dzięki mojemu doświadczeniu w fortelach i naukach Maski, potrafię spojrzeć na sytuację z perspektywy, która może przeważyć szalę zwycięstwa w trudnych chwilach.~
@2065 = ~Po pierwsze, szkolenie wyostrzyło moją zdolność analizy sytuacji. Widzę głębiej niż inni.~
@2066 = ~Potrafię udzielić nieocenionych rad przy planowaniu skoków czy misji, przewidując pułapki i okazje, które umknęłyby niewprawnemu oku.~
@2067 = ~Po drugie, moja znajomość struktur Kościoła Maski i jego metod to atut w poruszaniu się po szerszym świecie szpiegostwa Faerûnu.~
@2068 = ~Te informacje mogą być kluczowe, by wyprzedzić ruchy rywali, a nawet tych, którzy chcieliby zostać naszymi sojusznikami.~
@2069 = ~Wiedza to potęga, a w naszym fachu oznacza różnicę między sukcesem a stryczkiem.~
@2070 = ~Co więcej, wnoszę w nasze działania pierwiastek duchowy. Moje modlitwy i rytuały mają na celu zapewnienie nam przychylności Maski.~
@2071 = ~Może się to objawiać subtelnie – nagły cień, w którym można się schować, odwrócenie uwagi strażnika w idealnym momencie, czy po prostu intuicja, która podpowiada, co wybrać.~
@2072 = ~Ponadto mogę szkolić naszych członków w sztuce skradania się i forteli.~
@2073 = ~Moja biegłość w unikach, kamuflażu i cichym poruszaniu się jest nieoceniona dla każdego, kto chce być mistrzem złodziejstwa.~
@2074 = ~Choć moja rola może wydawać się nieuchwytna, korzyści, które przynoszę, są mocno wplecione w nasze operacje.~
@2075 = ~Jestem tu po to, by każdy nasz ruch był nie tylko precyzyjnie wykonany, ale i solidny strategicznie oraz pobłogosławiony przez cienie.~
@2076 = ~Razem możemy osiągnąć wielkość. Każda kradzież i każdy spisek nie będą zwykłym przestępstwem, lecz mistrzowskim tańcem w ciemności, pod batutą mądrości Maski.~
@2077 = ~Chciałbym dowiedzieć się czegoś o tobie, Daniko. Co możesz mi o sobie powiedzieć?~ ~Chciałabym dowiedzieć się czegoś o tobie, Daniko. Co możesz mi o sobie powiedzieć?~
@2078 = ~Och, ciekawi cię moja skromna osoba? Cóż, nieczęsto ktoś pyta o moją historię, ale mogę zdradzić to, co istotne.~
@2079 = ~Pochodzę z Thay. Tam, w jednej z naszych licznych świątyń, szkolono mnie w skradaniu się, strategii i świętych tajemnicach.~
@2080 = ~Tam szlifowałam umiejętności szpiegowskie, uczyłam się interpretować sekrety i zgłębiałam zawiłe rytuały Maski.~
@2081 = ~To rygorystyczne szkolenie uczyniło ze mnie demarchini – biegłą zarówno w subtelnościach wiary, jak i w praktyce naszej tajnej roboty.~
@2082 = ~Gdy awansowałam w szeregach Kościoła, przełożeni zdecydowali, by wysłać mnie tutaj, do Oka Gorgony.~
@2083 = ~Pod okiem mojego mistrza, Saradina, mam wplatać wolę i mądrość Maski w strategię gildii, wspierając wasze działania boską wiedzą i sprytem.~
@2084 = ~Jestem tu krótko, wciąż się adaptuję i obserwuję, ale każdy mój krok i każda decyzja są odbiciem mojego szkolenia i oddania Masce.~
@2085 = ~Jestem tu, by służyć, nauczać i uczyć się – zawsze pod czujnym okiem mistrza i naszego zagadkowego bóstwa.~
@2086 = ~Rozmawiał już ze mną o tym. Uważam, że ta propozycja idealnie współgra z moimi obowiązkami jako demarchini Maski.~
@2087 = ~Jako przedstawicielka Kościoła mam nie tylko szerzyć wpływy Pana Cieni, ale i stosować nabyte umiejętności w praktyce.~
@2088 = ~Pamiętaj, że moje zaangażowanie to wyraz oddania Masce i drodze, którą dla mnie wyznaczył. Razem stawimy czoła wyzwaniom, kierując się dogmatami mojej wiary.~
@2089 = ~Choć dołączam do ciebie z poczucia obowiązku, dołożę wszelkich starań, by nasza współpraca była skuteczna i służyła zarówno naszym celom, jak i interesom Kościoła.~
@2090 = ~Twoje umiejętności i oddanie robią wrażenie, Daniko. Chcę, żebyś ze mną ruszyła.~
@2091 = ~Ciekawi mnie, co ty o tym myślisz. Dobrze się czujesz z tym układem, czy to dla ciebie tylko suchy obowiązek?~
@2092 = ~Doceniam ofertę, ale myślę, że na razie lepiej będzie, jeśli zostaniemy przy obecnym układzie.~
@2093 = ~Moje osobiste odczucia? To... nie jest pytanie, które słyszę często. Prawdę mówiąc, moim życiem zawsze kierowała wola innych.~
@2094 = ~Nauczyłam się dostosowywać i błyszczeć w rolach, które mi powierzano. Odnajduję cel w wykonywaniu rozkazów.~
@2095 = ~Ta nowa funkcja – praca u twego boku – to po prostu kolejny rozkaz. Wypełnię go najlepiej jak potrafię, tak jak zawsze.~
@2096 = ~Troska o mój komfort jest... zbędna. Wykonam swoje zadania z pełnym oddaniem i precyzją. Nauki Kościoła zahartowały mnie i nauczyły skupienia.~
@2097 = ~Niemniej doceniam to pytanie. Jest... niespodziewane, ale nie nieprzyjemne. Po prostu w życiu, które wiodłam, wygoda nigdy nie była priorytetem.~
@2098 = ~Zawsze skupiałam się na wyższych celach, na potrzebach Kościoła, a teraz na wspieraniu naszych wspólnych działań w Oku Gorgony.~
@2099 = ~Rozumiem twoją decyzję. Moim obowiązkiem jest być przydatną tam, gdzie przyniosę najwięcej korzyści. Będę gotowa, gdy zajdzie potrzeba.~
@2100 = ~Gdyby sytuacja uległa zmianie lub gdybyś w przyszłości potrzebował mojej pomocy, nie wahaj się mnie wezwać.~ ~Gdyby sytuacja uległa zmianie lub gdybyś w przyszłości potrzebowała mojej pomocy, nie wahaj się mnie wezwać.~
@2101 = ~Na razie skupię się na moich obecnych sprawach i dopilnuję, by moja obecność tutaj służyła celom Pana Cieni i Oka Gorgony.~
@2102 = ~Dziękuję. Przyjmuję zaproszenie. Wierzę, że łącząc sztukę skradania i strategii z twoimi talentami, możemy zdziałać wiele.~
@2103 = ~Jestem gotowa na tę podróż. Zobaczymy, dokąd poprowadzą nas cienie.~
@2104 = ~Nie byłam pewna, czy nasze drogi skrzyżują się tak szybko. Jeśli zastanawiasz się, czy znów mnie przyjąć, wiedz, że pozostaję w gotowości.~
@2105 = ~Moje oddanie naszym wspólnym celom nie osłabło. Mogę podjąć pracę tam, gdzie ją przerwaliśmy, bez chwili zwłoki.~
@2106 = ~Wybór należy jednak do ciebie. Jeśli uznasz, że moje talenty znów są ci potrzebne, jestem do dyspozycji.~
@2107 = ~Przemyślałem to i doszedłem do wniosku, że twoje umiejętności są nam niezbędne. Chcę, żebyś do nas wróciła, Daniko.~ ~Przemyślałam to i doszłam do wniosku, że twoje umiejętności są nam niezbędne. Chcę, żebyś do nas wróciła, Daniko.~
@2108 = ~Doceniam twoją gotowość, Daniko, ale obecny skład drużyny całkiem nieźle się sprawdza. Lepiej będzie, jeśli na razie zostanie tak, jak jest.~
@2109 = ~Rozumiem. Będę więc kontynuować swe zadania na własną rękę. Ścieżka Maski często wymaga samotności, nie jest mi ona obca.~
@2110 = ~Gdybyś w przyszłości potrzebował moich umiejętności, wiesz, gdzie mnie szukać. Powodzenia w podróży, ja będę pilnować własnych spraw.~ ~Gdybyś w przyszłości potrzebowała moich umiejętności, wiesz, gdzie mnie szukać. Powodzenia w podróży, ja będę pilnować własnych spraw.~
@2111 = ~Przyjmuję twoją decyzję o moim powrocie. Podejmę swe obowiązki z takim samym oddaniem, jak poprzednio.~
@2112 = ~Nasze cele są jasne, a ja jestem gotowa służyć im swymi umiejętnościami. Ruszajmy do zadań, które na nas czekają. Niech Maska nam sprzyja.~